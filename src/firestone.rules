rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Products and Reviews
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null; // Allows admins to manage catalog, and logged-in users to update rating aggregates.
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow write: if request.auth != null; // Allows any authenticated user to leave a review.
      }
    }
    
    // Carts (Secured: Users can only manage their own cart)
    match /carts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Orders
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    
    // Users (Profiles Sync)
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}